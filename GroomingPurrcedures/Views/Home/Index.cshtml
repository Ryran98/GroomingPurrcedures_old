@{
    ViewData["Title"] = "Home Page";
}

    <div class="container" style="justify-content: center; padding-top: 3rem;">
        <div class="row">
            <div class="col-6" style="display: flex;">
                <div id="myCarousel" class="carousel slide" style="width: 540px;" data-ride="carousel" data-interval="6000">
                    <ol class="carousel-indicators">
                        <li data-target="#myCarousel" data-slide-to="0" class="active"></li>
                        <li data-target="#myCarousel" data-slide-to="1"></li>
                        <li data-target="#myCarousel" data-slide-to="2"></li>
                    </ol>
                    <div class="carousel-inner" role="listbox">
                        <div class="carousel-item active">
                            <img src="~/images/Budzi.jpg" alt="Budzi" class="img-responsive" height="540" width="540" />
                            <div class="carousel-caption" role="option">
                                <p>Random Review 1 here, wow so great *****</p>
                                <p>~ Happy Customer 1</p>
                            </div>
                        </div>
                        <div class="carousel-item">
                            <img src="~/images/Sophie.jpg" alt="Sophie" class="img-responsive" height="540" width="540" />
                            <div class="carousel-caption" role="option">
                                <p>Random Review 2 here, wow so great *****</p>
                                <p>~ Happy Customer 2</p>
                            </div>
                        </div>
                        <div class="carousel-item">
                            <img src="~/images/Leon.jpg" alt="Leon" class="img-responsive" height="540" width="540" />
                            <div class="carousel-caption" role="option">
                                <p>Random Review 3 here, wow so great *****</p>
                                <p>~ Happy Customer 3</p>
                            </div>
                        </div>
                    </div>
                    <a class="left carousel-control" href="#myCarousel" role="button" data-slide="prev">
                        <span class="glyphicon glyphicon-chevron-left" aria-hidden="true"></span>
                        <span class="sr-only">Previous</span>
                    </a>
                    <a class="right carousel-control" href="#myCarousel" role="button" data-slide="next">
                        <span class="glyphicon glyphicon-chevron-right" aria-hidden="true"></span>
                        <span class="sr-only">Next</span>
                    </a>
                </div>
            </div>
            <div class="col-6">
                <p>
                    I am a mobile cat groomer based in Tewkesbury, covering Gloucestershire and parts of Worcestershire.
                </p>
                <p>
                    I got into grooming as 3 of my own long-haired moggies had problems with knots and matts which left
                    them grumpy, discontented and not wanting to be touched. I wanted to help them to be comfortable
                    and enjoy life again.
                    Being 95.6% tiger, most domestic cats don't appreciate what we call "a luxury pamper" - bath blow dry
                    and style.
                </p>
                <p>
                    Yes, on occasion, they will need this, but my aim is to get them as comfortable as possible with as
                    little stress as possible
                </p>
                <p>
                    Our cats give us hours of joy and comfort. They teach us love, empathy and compassion and I'd like to
                    help you give back to them by keeping them comfortable in their coats.
                </p>
            </div>
        </div>
        <iframe src="https://www.facebook.com/plugins/post.php?href=https%3A%2F%2Fwww.facebook.com%2Fsarah.woods.5268750%2Fposts%2F10219437777197061&width=500&show_text=true&appId=3570445279713180&height=676"
                width="500" height="676" style="border:none;overflow:hidden" scrolling="no" frameborder="0" allowfullscreen="true"
                allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"></iframe>
        <iframe src="https://www.facebook.com/plugins/post.php?href=https%3A%2F%2Fwww.facebook.com%2FHelenferndawson%2Fposts%2F10157500568542084&width=500&show_text=true&appId=3570445279713180&height=694"
                width="500" height="694" style="border:none;overflow:hidden" scrolling="no" frameborder="0" allowfullscreen="true"
                allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"></iframe>
    </div>

